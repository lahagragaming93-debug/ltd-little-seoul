# ============================================================
# Bot Discord LTD Little Seoul — variables d'environnement
# Copie ce fichier vers .env et remplis les valeurs
# ============================================================

# Token du bot Discord (Discord Developer Portal → Application → Bot → Reset Token)
DISCORD_TOKEN=

# ID du serveur Discord (clic-droit serveur → Copier l'ID, mode développeur activé)
GUILD_ID=

# URL de la Cloud Function botIngest (après firebase deploy, format :
# https://botingest-xxx.europe-west1.run.app)
INGEST_URL=

# Token partagé bot ↔ Cloud Function (mettre la même valeur que le secret
# LTD_BOT_INGEST_TOKEN défini avec : firebase functions:secrets:set LTD_BOT_INGEST_TOKEN)
INGEST_TOKEN=

# IDs des canaux à surveiller (clic-droit canal → Copier l'ID)
CH_LOGS_IG=
CH_LOGS_SERVICES=
CH_SUIVI_SERVICE_VENDEUR=
CH_SUIVI_FACTURE=
CH_SUIVI_ACHAT_ESSENCE=
CH_DEPENSES=
CH_PAIE=
CH_SUIVI_COFFRE=

# Canaux supplémentaires (logs bruts — facultatif)
CH_SUIVI_COFFRE_SECONDAIRE=
CH_ALERTE_COFFRE=
CH_REVENU=
CH_FACTURES=
CH_STATSBANK=
CH_LOGS_LICENCIEMENT=
CH_LOGS_AVERTISSEMENT=

# Canaux RH automatisés (parsers structurés)
CH_AUTO_RH=
CH_AUTORANKUP=
CH_DOSSIERS_EMPLOYES=
CH_LOGS_VEHICULES=
CH_STAGIAIRE=

# Canaux pompistes / ventes / dashboard stations
CH_POMPISTE=
CH_VENTES=
CH_STATIONS_DASHBOARD=
